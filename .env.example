# VeriCleri — Environment Variables Template
# ─────────────────────────────────────────────────────────────────
# STEP 1: Copy this file and rename it to:  .env
#         (remove the .example part)
# STEP 2: Fill in your own values below
# STEP 3: Never share or upload the .env file — it stays private
# ─────────────────────────────────────────────────────────────────

# Flask secret key — change this to any long random string
SECRET_KEY=change-this-to-a-long-random-secret-key-2026

# Set to "development" while testing locally
# Set to "production" when deploying online
FLASK_ENV=development

# Admin API key — leave blank to disable protected endpoints
ADMIN_API_KEY=
